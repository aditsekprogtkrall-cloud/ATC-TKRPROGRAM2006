        window.downloadPDF = () => {
            const { jsPDF } = window.jspdf;
            const target = document.getElementById('ukk-export-area');
            html2canvas(target, { scale: 2, useCORS: true }).then(canvas => {
                const imgWidth = 210; const pageHeight = 295;
                const imgHeight = (canvas.height * imgWidth) / canvas.width;
                let heightLeft = imgHeight;
                const doc = new jsPDF('p', 'mm', 'a4');
                let position = 0;
                doc.addImage(canvas.toDataURL('image/png'), 'PNG', 0, position, imgWidth, imgHeight);
                heightLeft -= pageHeight;
                while (heightLeft >= 0) {
                    position = heightLeft - imgHeight; doc.addPage();
                    doc.addImage(canvas.toDataURL('image/png'), 'PNG', 0, position, imgWidth, imgHeight);
                    heightLeft -= pageHeight;
                }
                doc.save('Jadwal_UKK_Official_159_Siswa.pdf');
            });
        };

