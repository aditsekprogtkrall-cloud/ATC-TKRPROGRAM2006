                        </div>
                    </div>

                    <div id="ukk-export-area" class="print-area overflow-x-auto p-8 bg-white text-center">
                        <div class="text-center mb-8">
                            <h1 class="text-2xl font-black uppercase">JADWAL UJI KOMPETENSI KEJURUAN (UKK)</h1>
                            <h2 class="text-xl font-bold uppercase">SMK KARYA BAHANA MANDIRI 1 BEKASI</h2>
                            <p class="text-[10pt] font-semibold uppercase tracking-widest">Program Keahlian: Teknik Kendaraan Ringan Otomotif | TP 2025/2026</p>
                            <hr class="my-4 border-black border-2">
                        </div>
                        <table class="w-full border-collapse border border-black text-center" id="ukk-table-data">
                            <thead class="bg-slate-100 font-bold uppercase text-center">
                                <tr class="text-[8pt]">
                                    <th class="border border-black py-3 px-1 w-8 text-center">NO.</th>
                                    <th class="border border-black px-2 w-32 text-center">HARI & TANGGAL</th>
                                    <th class="border border-black px-2 w-36 text-center">SESI & WAKTU KERJA</th>
                                    <th class="border border-black px-2 w-20 text-center">NIPD</th>
                                    <th class="border border-black px-3 text-left">NAMA PESERTA UJIAN</th>
                                    <th class="border border-black px-1 w-8 text-center">L/P</th>
                                    <th class="border border-black px-2 w-16 text-center">KELAS</th>
                                    <th class="border border-black px-2 w-24 text-center">RUANG</th>
                                    <th class="border border-black px-2 w-44 text-red-700 text-center">PENGUJI</th>
                                </tr>
                            </thead>
                            <tbody id="tbody-ukk" class="text-[7.5pt] font-semibold text-center"></tbody>
                        </table>
                        <div class="mt-12 flex justify-between items-start w-full px-4 text-left">
                            <div class="text-[9pt] border-l-4 border-red-600 pl-4 bg-gray-50 py-4 pr-6 max-w-xl text-left">
                                <p class="font-black underline italic text-red-700 mb-2">CATATAN PENTING PESERTA:</p>
