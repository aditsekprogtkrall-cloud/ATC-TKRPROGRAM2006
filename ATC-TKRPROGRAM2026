                <div class="bg-white p-4 rounded-xl shadow-md border-t-4 border-blue-500 text-center"><img src="https://iili.io/qY1hlnV.jpg" class="foto-3x4 mx-auto mb-3 font-bold text-center"><h3 class="font-bold text-xs">Syaiful Hadi, S.T, Gr</h3><p class="text-blue-500 text-[9px] font-bold uppercase mt-1">Instruktur TKR</p></div>
                <div class="bg-white p-4 rounded-xl shadow-md border-t-4 border-indigo-500 text-center"><img src="https://iili.io/qY1jHDx.md.jpg" class="foto-3x4 mx-auto mb-3 font-bold text-center"><h3 class="font-bold text-xs text-center">Defa Andrian, S.T, Gr</h3><p class="text-indigo-600 text-[9px] font-bold uppercase mt-1">Instruktur TKR</p></div>
                <div class="bg-white p-4 rounded-xl shadow-md border-t-4 border-purple-500 text-center text-center"><img src="https://iili.io/qY1jDsp.md.jpg" class="foto-3x4 mx-auto mb-3 font-bold text-center text-center"><h3 class="font-bold text-xs text-center text-center">Agus Rizky, S.T</h3><p class="text-purple-600 text-[9px] font-bold uppercase mt-1 text-center text-center">Instruktur TKR</p></div>
            </div>

            <div class="mt-12 text-left">
                <div class="flex items-center gap-3 mb-6">
