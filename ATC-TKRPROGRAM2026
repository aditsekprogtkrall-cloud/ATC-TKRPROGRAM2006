            </div>
        </nav>
        <div class="marquee-wrapper"><span class="marquee-text" id="running-text"></span></div>
    </header>

    <!-- MAIN CONTENT -->
    <main class="flex-grow container mx-auto px-4 py-8">

        <!-- 1. BERANDA -->
        <section id="beranda" class="tab-content block no-print space-y-12">
            <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100">
