                <button onclick="switchTab('jadwal-ukk', this)" class="nav-btn px-5 py-3 text-[10px] font-bold uppercase tracking-widest hover:bg-blue-800 transition text-yellow-400 font-black text-center">Jadwal UKK</button>
                <button onclick="switchTab('rekap-kehadiran', this)" class="nav-btn px-5 py-3 text-[10px] font-bold uppercase tracking-widest hover:bg-blue-800 transition text-center">Kehadiran</button>
