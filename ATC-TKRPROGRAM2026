            };
            display.value = waliMap[kls] || "";
        };

        window.handleLoginUKK = function() {
            const inputNama = document.getElementById('input-nama-ukk').value.trim().toUpperCase();
            const inputKelas = document.getElementById('input-kelas-ukk').value;
            const inputWali = document.getElementById('display-wali-ukk').value;

            if(!inputNama || !inputKelas) return alert("Harap isi Nama dan pilih Kelas!");

            const sIdx = allStudents.findIndex(n => n.includes(inputNama));
            if(sIdx === -1) return alert("Siswa tidak ditemukan dalam daftar 159 Peserta UKK.");

            // Success Transition
            const studentName = allStudents[sIdx];
            const nipd = "232410" + (100 + sIdx);
            const dayIdx = Math.floor(sIdx / 16);
            const dayObj = scheduleDays[dayIdx] || scheduleDays[scheduleDays.length - 1];
            const isSesi1 = (sIdx % 16 < 8);

            document.getElementById('card-name').innerText = studentName;
            document.getElementById('card-nipd').innerText = nipd;
            document.getElementById('card-kelas').innerText = inputKelas;
            document.getElementById('card-wali').innerText = inputWali;
            document.getElementById('card-day').innerText = dayObj.tgl;
            document.getElementById('card-sesi').innerText = isSesi1 ? "SESI 1 (PAGI)" : "SESI 2 (SIANG)";
            document.getElementById('card-time').innerText = isSesi1 ? "07:00 - 12:00 WIB" : "13:00 - 16:45 WIB";

            document.getElementById('login-ukk-siswa').classList.add('section-hidden');
            document.getElementById('content-jadwal-ukk').classList.remove('section-hidden');
            renderTableUKK();
        };

        window.renderTableUKK = function() {
            const tbody = document.getElementById('tbody-ukk');
            if(!tbody) return;
            const examiners = ["H. Irwan Rahmat, S.T, Gr", "H. Agus Rizky, S.T", "Adhitya A.R, S.T, Gr", "Firmansyah, S.T, Gr", "Defa Andrian, S.T, Gr"];
            let html = ''; let sIdx = 0; const perDay = Math.ceil(159 / scheduleDays.length);
            scheduleDays.forEach((day, dIdx) => {
                const limit = (dIdx === scheduleDays.length - 1) ? 159 : Math.min(159, sIdx + perDay);
                const batch = limit - sIdx;
                for (let i = 0; i < batch; i++) {
                    const studentName = allStudents[sIdx];
                    const gender = (studentName.includes("APRILIA") || studentName.includes("AINA")) ? "P" : "L";
                    html += `<tr class="hover:bg-gray-50 border-b border-black text-center">
                        <td class="border border-black p-1 text-center font-bold">${sIdx + 1}</td>`;
                    if(i === 0) html += `<td class="border border-black p-1 bg-slate-50 font-bold text-center" rowspan="${batch}">${day.tgl}</td>`;
                    if(i === 0 || i === 8) {
                        const sNum = (i < 8) ? "1" : "2";
                        const sTime = (i < 8) ? "07:00-12:00" : "13:00-16:45";
                        html += `<td class="border border-black p-1 text-center" rowspan="${(i<8)?Math.min(8,batch):(batch-8)}"><div class="session-title">SESI ${sNum}</div><div class="time-label">${sTime}</div></td>`;
                    }
                    html += `<td class="border border-black p-1 font-mono text-center">232410${100+sIdx}</td>
                        <td class="border border-black p-1 uppercase text-left font-bold">${studentName}</td>
                        <td class="border border-black p-1 font-black ${gender==='P'?'text-pink-600':''} text-center">${gender}</td>
                        <td class="border border-black p-1 font-bold text-blue-800 text-center">${sIdx < 42 ? "XII TKR 1" : sIdx < 83 ? "XII TKR 2" : sIdx < 123 ? "XII TKR 3" : "XII TKR 4"}</td>`;
                    if(i === 0) html += `<td class="border border-black p-1 bg-slate-50 uppercase text-[5pt] text-center font-black" rowspan="${batch}">BENGKEL TKR UTAMA</td>`;
                    if(sIdx % 4 === 0) html += `<td class="border border-black p-1 font-bold text-red-700 bg-red-50/20 uppercase text-center" rowspan="4">${examiners[Math.floor(sIdx/4)%examiners.length]}</td>`;
                    html += `</tr>`; sIdx++;
                }
            });
            tbody.innerHTML = html;
        };

