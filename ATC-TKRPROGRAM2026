        <!-- 2. JADWAL UKK -->
        <section id="jadwal-ukk" class="tab-content section-hidden">
            <!-- Form Identitas Login Siswa -->
            <div id="login-ukk-siswa" class="bg-white rounded-3xl shadow-2xl overflow-hidden max-w-2xl mx-auto border border-gray-100 no-print">
                <div class="bg-blue-700 p-6 text-white text-center">
                    <h3 class="text-2xl font-black uppercase tracking-tight">Identitas Peserta UKK</h3>
                    <p class="text-blue-100 text-xs mt-1">Sistem Jadwal UKK TKR - SMK KBM 1 Bekasi</p>
                </div>
                <div class="p-8 space-y-5 bg-slate-50/30">
                    <div class="space-y-4">
                        <div>
                            <label class="block text-[10px] font-black text-slate-500 uppercase mb-1 text-left">Nama Lengkap Siswa</label>
                            <input type="text" id="input-nama-ukk" placeholder="Tulis Nama Anda..." class="w-full px-4 py-3 rounded-xl border-2 border-slate-200 outline-none focus:border-blue-500 font-bold uppercase">
                        </div>
                        <div>
                            <label class="block text-[10px] font-black text-slate-500 uppercase mb-1 text-left">Kelas (XII TKR)</label>
                            <select id="input-kelas-ukk" onchange="updateWaliKelas(this.value)" class="w-full px-4 py-3 rounded-xl border-2 border-slate-200 outline-none focus:border-blue-500 font-bold text-slate-700">
                                <option value="">-- Pilih Kelas --</option>
                                <option value="XII TKR 1">XII TKR 1</option>
                                <option value="XII TKR 2">XII TKR 2</option>
                                <option value="XII TKR 3">XII TKR 3</option>
                                <option value="XII TKR 4">XII TKR 4</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-[10px] font-black text-slate-500 uppercase mb-1 text-left">Wali Kelas</label>
                            <input type="text" id="display-wali-ukk" readonly class="w-full px-4 py-3 rounded-xl border-2 border-slate-100 bg-slate-100 outline-none font-bold text-blue-800" placeholder="Pilih Kelas Dahulu">
                        </div>
                    </div>
                    <button onclick="handleLoginUKK()" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-black py-4 rounded-xl shadow-xl transition transform active:scale-95 uppercase tracking-widest text-center">
                        <i class="fas fa-list-alt mr-2"></i> Lihat Jadwal Ujian
                    </button>
                </div>
            </div>

            <div id="content-jadwal-ukk" class="section-hidden space-y-12">
                <!-- BAGIAN KHUSUS: KARTU PESERTA -->
                <div class="flex flex-col items-center space-y-6">
                    <h3 class="text-2xl font-black text-slate-800 uppercase tracking-tighter border-b-4 border-yellow-500 pb-1 text-center">Waktu Pelaksanaan Ujian (Khusus)</h3>
                    
                    <div id="kartu-khusus-area" class="kartu-ujian">
                        <div class="kartu-header">
                            <h4 class="font-black text-sm uppercase tracking-widest">KARTU PESERTA UKK 2026</h4>
                            <p class="text-[9px] opacity-80 uppercase">Teknik Kendaraan Ringan Otomotif</p>
                        </div>
                        <div class="kartu-body">
                            <div class="kartu-row"><div class="kartu-label text-left">NAMA</div><div class="kartu-value text-left" id="card-name">-</div></div>
                            <div class="kartu-row"><div class="kartu-label text-left">NIPD</div><div class="kartu-value text-left" id="card-nipd">-</div></div>
                            <div class="kartu-row"><div class="kartu-label text-left">KELAS</div><div class="kartu-value text-left" id="card-kelas">-</div></div>
                            <div class="kartu-row"><div class="kartu-label text-left">WALI KELAS</div><div class="kartu-value text-left text-[11px]" id="card-wali">-</div></div>
                            <div class="bg-blue-50 p-4 rounded-xl mt-4 border border-blue-100 text-left">
                                <div class="kartu-row border-none"><div class="kartu-label">HARI / TGL</div><div class="kartu-value text-blue-800" id="card-day">-</div></div>
                                <div class="kartu-row border-none"><div class="kartu-label text-blue-600">SESI</div><div class="kartu-value text-xl font-black text-blue-600" id="card-sesi">-</div></div>
                                <div class="kartu-row border-none"><div class="kartu-label">WAKTU</div><div class="kartu-value text-red-600 font-black text-lg" id="card-time">-</div></div>
                                <div class="kartu-row border-none"><div class="kartu-label">RUANG</div><div class="kartu-value uppercase">BENGKEL TKR UTAMA</div></div>
