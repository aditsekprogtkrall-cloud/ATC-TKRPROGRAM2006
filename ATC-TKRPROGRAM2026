                        </div>
                        <div class="flex flex-wrap gap-2">
                            <button onclick="downloadJPGGlobal()" class="bg-blue-600 text-white px-4 py-2 rounded-lg text-[10px] font-black uppercase shadow hover:bg-blue-700 transition">Download JPG Global</button>
                            <button onclick="downloadPDF()" class="bg-emerald-600 text-white px-4 py-2 rounded-lg text-[10px] font-black uppercase shadow hover:bg-emerald-700 transition">Download PDF Global</button>
