        // --- 3. CORE LOGIC FUNCTIONS ---
        window.updateWaliKelas = function(kls) {
            const display = document.getElementById('display-wali-ukk');
            const waliMap = {
                "XII TKR 1": "Endang Syaefudin, S.Pd.I, M.Si, Gr",
                "XII TKR 2": "Efa Laelatus Syarifah, S.Pd, Gr",
