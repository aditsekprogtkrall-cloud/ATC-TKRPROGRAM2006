                            </div>
                        </div>
                    </div>
                    <button onclick="downloadCard()" class="bg-blue-600 text-white px-6 py-2.5 rounded-full font-bold uppercase text-xs shadow-lg hover:bg-blue-700 transition">Download Kartu</button>
                </div>

